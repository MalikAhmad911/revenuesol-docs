              "guides/jobs",
              "guides/payments",
              "guides/reviews",
              "guides/mobile-app"
            ]
          },
          {
            "group": "Integrations",
            "pages": [
              "integrations/twilio",
              "integrations/ringcentral",
              "integrations/stripe",
              "integrations/quickbooks",
              "integrations/google"
            ]
          }
        ]
      },
      {
        "tab": "Developers",
        "groups": [
          {
            "group": "Developers",
            "pages": [
              "developers/introduction",
              "developers/webhooks",
              "developers/embeds"
            ]
          }
        ]
