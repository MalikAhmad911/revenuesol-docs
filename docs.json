      {
        "tab": "Help Center",
        "groups": [
          {
            "group": "Getting Started",
            "pages": ["introduction", "quickstart"]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/inbox",
              "guides/ai-employee",
              "guides/voice-agent",
